# evercrisp
# https://github.com/r4dixx/evercrisp
alias evercrisp='git --git-dir=$HOME/.evercrisp --work-tree=$HOME'

# Daemon Hunter
# https://github.com/PaulWoitaschek/DaemonHunter
alias daemon-hunter='~/Dev/Android/DaemonHunter/kill-daemons.main.kts'

# scrcpy
# https://github.com/Genymobile/scrcpy
alias scrcpy-custom='scrcpy --video-codec=h265 --max-size=1920 --max-fps=60 --no-audio --keyboard=uhid --stay-awake --disable-screensaver --turn-screen-off --show-touches'

# plex
alias sshfs-mount-plex='sshfs asus:/mnt/plex /Volumes/Plex\ HD -ovolname=Plex\ HD'
alias sshfs-unmount-plex='umount /Volumes/Plex\ HD'

